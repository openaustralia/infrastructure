#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/rekey-yaml — rewrite inline ansible-vault !vault blocks in YAML.
#
# Replaces the original rekey.rb. Used by bin/rotate-vault-passphrase to
# re-encrypt every block tagged with a given vault id, but also handles
# the migrate-between-ids case (the original rekey.rb's use case).
#
# Unlike rekey.rb this works in text mode (not via Psych), so comments,
# key order, and surrounding whitespace are preserved — only the
# !vault blocks themselves change.
#
# Usage:
#   bin/rekey-yaml \
#     --vault-id <old-id>@<old-source> \
#     --new-vault-id <new-id>@<new-source> \
#     [--in-place] \
#     FILE [FILE ...]
#
# Blocks tagged with an id other than <old-id> are left untouched. If
# --new-id differs from --old-id you'll migrate matching blocks to the
# new id; if they're the same you'll rotate the passphrase in place.

require "open3"
require "optparse"

# Preflight: ansible-vault must be reachable, otherwise the first
# Open3 call below dies with a `No such file or directory` stack trace.
unless system("command -v ansible-vault > /dev/null 2>&1")
  abort "ansible-vault not found on PATH — run `make venv` and activate the venv (or install ansible-core)"
end

old_id = old_source = new_id = new_source = nil
in_place = false

OptionParser.new do |opts|
  opts.banner = "Usage: #{$PROGRAM_NAME} --vault-id ID@SRC --new-vault-id ID@SRC [--in-place] FILE..."
  opts.on("--vault-id ID@SRC", "Source for decrypting matching blocks") do |v|
    old_id, old_source = v.split("@", 2)
  end
  opts.on("--new-vault-id ID@SRC", "Target id + source for re-encryption") do |v|
    new_id, new_source = v.split("@", 2)
  end
  opts.on("--in-place", "Rewrite FILE in place (default: write to stdout)") { in_place = true }
end.parse!

abort "Missing --vault-id ID@SRC" if old_id.nil? || old_source.nil?
abort "Missing --new-vault-id ID@SRC" if new_id.nil? || new_source.nil?
abort "No input files" if ARGV.empty?

# `context` is a short string describing what failed (e.g. file path and
# block header excerpt). It's surfaced in the abort message so rotation
# failures don't need a separate detective phase.
def shell(*cmd, stdin:, context:)
  out, err, status = Open3.capture3(*cmd, stdin_data: stdin)
  unless status.success?
    abort "#{cmd.first} failed (#{context}): #{err.strip}"
  end
  out
end

def decrypt(blob, id, src, context:)
  shell("ansible-vault", "decrypt", "--vault-id", "#{id}@#{src}",
        stdin: blob, context: "decrypt #{context}")
end

def encrypt(plain, id, src, context:)
  shell(
    "ansible-vault", "encrypt",
    "--vault-id", "#{id}@#{src}",
    "--encrypt-vault-id", id,
    stdin: plain, context: "encrypt #{context}"
  )
end

def rekey(text, old_id, old_source, new_id, new_source, path)
  lines = text.lines
  out = []
  i = 0
  block_no = 0
  while i < lines.length
    line = lines[i]
    out << line
    i += 1

    # Look for "<anything> !vault |" line.
    next unless line =~ /!vault\s*\|\s*\z/
    block_no += 1

    # Find body indent from the next non-blank line.
    j = i
    j += 1 while j < lines.length && lines[j].strip.empty?
    break if j >= lines.length

    indent = lines[j][/\A[ \t]+/]
    break if indent.nil? || indent.empty?

    # Collect body lines: must have the body indent and a non-whitespace
    # character immediately after it. A blank line or a dedent terminates
    # the block (matches how the inline !vault literal-block scalar is
    # written in this repo: contiguous hex lines, no blanks inside).
    body = []
    while i < lines.length && lines[i] =~ /\A#{Regexp.escape(indent)}\S/
      body << lines[i]
      i += 1
    end

    blob = body.map { |l| l.start_with?(indent) ? l[indent.length..] : l }.join
    header = blob.lines.first.to_s.strip
    # Treat unlabeled 1.1 headers ($ANSIBLE_VAULT;1.1;AES256) as `default`
    # — that's the effective vault id ansible assigns when none is tagged.
    # Without this, a `default` rotation would silently skip every 1.1 block.
    block_id = header.split(";")[3] || "default"
    ctx = "#{path} block ##{block_no} (#{header})"

    if block_id == old_id
      plain = decrypt(blob, old_id, old_source, context: ctx)
      cipher = encrypt(plain, new_id, new_source, context: ctx)
      cipher += "\n" unless cipher.end_with?("\n")
      out << cipher.lines.map { |l| indent + l }.join
    else
      out << body.join
    end
  end
  out.join
end

ARGV.each do |path|
  rewritten = rekey(File.read(path), old_id, old_source, new_id, new_source, path)
  if in_place
    # Write to a sibling temp file then rename, so a kill mid-write
    # can't leave the YAML half-rewritten. Rename is atomic within
    # the same filesystem.
    tmp = "#{path}.tmp.#{Process.pid}"
    begin
      File.write(tmp, rewritten)
      File.rename(tmp, path)
    rescue StandardError
      File.delete(tmp) if File.exist?(tmp)
      raise
    end
  else
    print rewritten
  end
end
