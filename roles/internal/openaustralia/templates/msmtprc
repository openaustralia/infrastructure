# {{ ansible_managed }}

account catch_email
syslog LOG_MAIL
{% if catch_email_host %}
  # Send caught mail to remote service
  tls off
  host {{ catch_email_host }}
  port {{ catch_email_port }}
  {% if catch_email_user %}
    auth {{ catch_email_auth }}
    user {{ catch_email_user }}
    {% if catch_email_password %}
      password {{ catch_email_password }}
    {% endif %}
  {% else %}
    auth off
  {% endif %}
{% else %}
  # No CATCH_EMAIL_HOST defined when provisioning, logging header and failing on closed port
  tls off
  host 127.0.0.1
  # extremly unlikely to have a service as its not allocated
  port 4
  auth off
{% endif %}

{% if 'catch_all_mail' in group_names %}
  # All email is caught
  account default : catch_email
{% else %}
  account cuttlefish
  syslog LOG_MAIL
  tls on
  # For some reason we're not able to correctly verify the certs
  # TODO: Figure out what's going on and fix this
  #tls_trust_file /etc/ssl/certs/ca-certificates.crt
  tls_certcheck off
  host cuttlefish.oaf.org.au
  port 2525
  auth on
  user {{ cuttlefish_username }}
  password {{ cuttlefish_password }}

  account default : cuttlefish
{% endif %}
